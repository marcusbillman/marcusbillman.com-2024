---
import CaseStudiesSection from '@/components/sections/CaseStudiesSection';
import ContactSection from '@/components/sections/ContactSection';
import HeaderSection from '@/components/sections/HeaderSection';
import SeparatorSection from '@/components/sections/SeparatorSection';
import Layout from '@/layouts/Layout.astro';
import { getAllCaseStudies } from '@/utils/content';
import { t } from '@/utils/i18n';

const caseStudies = await getAllCaseStudies();
---

<Layout title={t('portfolio.title')}>
  <HeaderSection
    slot="header"
    client:load
    title={t('portfolio.heading')}
    emoji={['✨', '🎨', '📄', '🖋️', '🗃️']}
  />
  <CaseStudiesSection client:idle caseStudies={caseStudies} />
  <SeparatorSection />
  <ContactSection client:visible />
</Layout>
