---
import { t } from '@/utils/i18n';
import Button from '../Button';
import DotGrid from '../DotGrid';

export interface MetadataBlockProps {
  date?: string;
  fields?: { key: string; values: string[] }[];
  links?: { text: string; url: string }[];
}

const { date, fields, links } = Astro.props as MetadataBlockProps;
---

<div class="my-16 space-y-6 lg:my-24 lg:space-y-8">
  <dl class="mx-auto max-w-4xl divide-y rounded-2xl border">
    {
      date && (
        <div class="flex gap-4 p-4">
          <dt class="block w-32 max-w-[25vw] flex-shrink-0 font-serif font-medium italic text-subtle">
            {t('caseStudy.date')}
          </dt>
          <dd class="flex-grow">{date}</dd>
        </div>
      )
    }
    {
      fields &&
        fields.map((field) => (
          <div class="flex gap-4 p-4">
            <dt class="block w-32 max-w-[25vw] flex-shrink-0 font-serif font-medium italic text-subtle">
              {field.key}
            </dt>
            <dd class="flex-grow">
              <ul>
                {field.values.map((value, index) => (
                  <li class="inline">
                    {value}
                    {field.values.length &&
                      index < field.values.length - 1 &&
                      ' • '}
                  </li>
                ))}
              </ul>
            </dd>
          </div>
        ))
    }
  </dl>
  {
    links && (
      <div class="relative isolate mx-auto flex max-w-4xl flex-wrap justify-center gap-4 rounded-2xl border p-8 lg:p-16">
        {links.map((link, index) => (
          <Button
            text={link.text}
            href={link.url}
            style={index === 0 ? 'default' : 'subtle'}
          />
        ))}
        <DotGrid />
      </div>
    )
  }
</div>
