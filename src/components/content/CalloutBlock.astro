---
import { InfoIcon, WarningIcon } from '@phosphor-icons/react/dist/ssr';
import { twMerge } from 'tailwind-merge';

interface CalloutBlockProps {
  text: string;
  icon?: 'info' | 'warning' | 'none';
  class?: string;
}

const { text, icon = 'info', ...props } = Astro.props as CalloutBlockProps;
---

<div class={twMerge('mx-auto mt-[1em] max-w-4xl text-xl', props.class)}>
  <div class="mx-auto flex max-w-4xl gap-2 rounded-2xl bg-subtle p-4">
    {
      icon === 'info' && (
        <InfoIcon size={20} className="mt-[0.25em] shrink-0 text-primary" />
      )
    }
    {
      icon === 'warning' && (
        <WarningIcon size={20} className="mt-[0.25em] shrink-0 text-warning" />
      )
    }
    <p class="flex flex-col gap-2">{text}</p>
  </div>
</div>
