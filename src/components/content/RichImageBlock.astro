---
import type { ImageMetadata } from 'astro';

import { Image } from 'astro:assets';
import { twMerge } from 'tailwind-merge';

export type RichImage = {
  astroImage: ImageMetadata;
  alt: string;
  caption?: string;
};

export interface RichImageBlockProps {
  image: RichImage;
  className?: string;
}

const { image, className = '' } = Astro.props as RichImageBlockProps;
---

<figure
  class={twMerge(
    'relative my-16 max-h-screen flex-col overflow-hidden rounded-2xl lg:my-24 lg:rounded-4xl',
    className,
  )}
>
  <Image
    src={image.astroImage}
    alt={image.alt}
    loading="lazy"
    class="h-full w-full object-cover"
  />
  {
    image.caption && (
      <figcaption class="absolute inset-0 top-auto bg-gradient-to-b from-black/0 to-black/50 p-4 font-serif italic text-gray-100 lg:p-6">
        {image.caption}
      </figcaption>
    )
  }
</figure>
