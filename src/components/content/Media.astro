---
import type { ImageMetadata } from 'astro';

import { Image } from 'astro:assets';
import { twMerge } from 'tailwind-merge';

type ImageMedia = {
  type: 'image';
  astroImage: ImageMetadata;
  alt: string;
  caption?: string;
};

type VideoMedia = {
  type: 'video';
  src: string;
  caption?: string;
};

export type MediaType = ImageMedia | VideoMedia;

export interface MediaBlockProps {
  media: MediaType;
  className?: string;
}

const { media, className = '' } = Astro.props as MediaBlockProps;
---

<figure class={twMerge('my-16 flex flex-col gap-3 lg:my-24', className)}>
  {
    media.type === 'video' ? (
      <a href={media.src} target="_blank">
        <video
          src={media.src}
          autoplay
          muted
          loop
          playsinline
          class="w-full rounded-2xl border border-default"
        />
      </a>
    ) : (
      <a href={media.astroImage.src} target="_blank">
        <Image
          src={media.astroImage}
          alt={media.alt}
          loading="lazy"
          class="w-full rounded-2xl border border-default"
        />
      </a>
    )
  }
  {
    media.caption && (
      <figcaption class="text-subtle">{media.caption}</figcaption>
    )
  }
</figure>
