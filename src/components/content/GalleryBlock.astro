---
import type { Media } from './MediaBlock.astro';

import MediaBlock from './MediaBlock.astro';

export interface GalleryBlockProps {
  items: Media[];
}

const { items } = Astro.props as GalleryBlockProps;
---

<div class="my-16 flex flex-wrap justify-stretch gap-4 lg:my-24 lg:gap-8">
  {
    items.map((item: Media) => (
      <MediaBlock media={item} className="my-0 grow basis-lg lg:my-0" />
    ))
  }
</div>
