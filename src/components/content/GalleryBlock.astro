---
import type { RichImage } from './RichImageBlock.astro';

import RichImageBlock from './RichImageBlock.astro';

export interface GalleryBlockProps {
  images: RichImage[];
}

const { images } = Astro.props as GalleryBlockProps;
---

<div class="my-16 flex flex-wrap justify-stretch gap-4 lg:my-24 lg:gap-8">
  {
    images.map((image: RichImage) => (
      <RichImageBlock
        image={image}
        className="my-0 flex-grow basis-128 lg:my-0"
      />
    ))
  }
</div>
