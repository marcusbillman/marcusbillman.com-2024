---
import type { ImageMetadata } from 'astro';

import { Image } from 'astro:assets';
import { twMerge } from 'tailwind-merge';

type ImageMedia = {
  type: 'image';
  astroImage: ImageMetadata;
  alt: string;
  caption?: string;
};

type VideoMedia = {
  type: 'video';
  src: string;
  caption?: string;
};

export type Media = ImageMedia | VideoMedia;

export interface MediaBlockProps {
  media: Media;
  className?: string;
}

const { media, className = '' } = Astro.props as MediaBlockProps;
---

<figure
  class={twMerge(
    'relative my-16 max-h-screen flex-col overflow-hidden rounded-2xl lg:my-24 lg:rounded-4xl',
    className,
  )}
>
  {
    media.type === 'video' ? (
      <video
        src={media.src}
        autoplay
        muted
        loop
        playsinline
        class="h-full w-full object-cover"
      />
    ) : (
      <Image
        src={media.astroImage}
        alt={media.alt}
        loading="lazy"
        class="h-full w-full object-cover"
      />
    )
  }
  {
    media.caption && (
      <figcaption class="absolute inset-0 top-auto bg-gradient-to-b from-black/0 to-black/50 p-4 font-serif italic text-gray-100 lg:p-6">
        {media.caption}
      </figcaption>
    )
  }
</figure>
