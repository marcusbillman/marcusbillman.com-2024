---
import type { ImageMetadata } from 'astro';

import { Image } from 'astro:assets';
import { twMerge } from 'tailwind-merge';

type ImageMedia = {
  type: 'image';
  astroImage: ImageMetadata;
  alt: string;
  caption?: string;
};

type VideoMedia = {
  type: 'video';
  src: string;
  caption?: string;
};

export type Media = ImageMedia | VideoMedia;

export interface MediaBlockProps {
  media: Media;
  className?: string;
}

const { media, className = '' } = Astro.props as MediaBlockProps;
---

<figure class={twMerge('my-16 flex flex-col gap-4 lg:my-24', className)}>
  {
    media.type === 'video' ? (
      <video
        src={media.src}
        autoplay
        muted
        loop
        playsinline
        class="w-full rounded-2xl lg:rounded-4xl"
      />
    ) : (
      <Image
        src={media.astroImage}
        alt={media.alt}
        loading="lazy"
        class="w-full rounded-2xl lg:rounded-4xl"
      />
    )
  }
  {
    media.caption && (
      <figcaption class="text-subtle lg:px-8">{media.caption}</figcaption>
    )
  }
</figure>
